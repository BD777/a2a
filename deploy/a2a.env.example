# A2A service env. Loaded by systemd via EnvironmentFile=.
# All keys are optional; defaults live in src/config.js.

# A2A_TIME_ZONE=Asia/Shanghai
# A2A_FEISHU_DOMAIN=feishu        # feishu | lark | https://your-open-platform-host
# A2A_MAX_TURNS_SINCE_USER=100   # default 100; raise if you want longer auto-debates
# A2A_FEISHU_CHUNK_LIMIT=3500    # max chars per Feishu text reply; long content is split
# A2A_FEISHU_PAGE_SIZE_CAP=50    # Feishu im.message.list per-page cap
# A2A_SEEN_MESSAGE_LIMIT=5000    # de-dup ring size for incoming Feishu messages

# Streaming card (typewriter effect for assistant text + thinking).
# Requires the Feishu app to have the `cardkit:card:write` scope; falls back
# to non-streaming cards if the scope is missing.
# A2A_FEISHU_STREAMING=false             # master switch (default off)
# A2A_FEISHU_STREAM_TEXT_MS=800          # text-element flush throttle
# A2A_FEISHU_STREAM_THINK_MS=1500        # thinking-element flush throttle
# A2A_FEISHU_STREAM_TEXT_MIN_CHARS=30    # skip flush if text grew by less than this

# Per-cliId card header colors. agents.json `cardColor` is the per-agent default;
# these env vars override it (and let you tweak system levels) without editing agents.json.
# Values are JSON objects with Feishu interactive-card template names
# (blue, turquoise, indigo, purple, carmine, red, orange, yellow, green, grey, …).
# A2A_CARD_AGENT_COLORS={"claude-code":"blue","codex":"turquoise"}
# A2A_CARD_SYSTEM_COLORS={"info":"grey","warn":"yellow","error":"red"}

# Localized lifecycle / prompt strings. JSON file mapping template keys to strings.
# Defaults live in src/protocol/messages.js. See config/messages.zh-CN.example.json
# for a Chinese sample. If config/messages.json exists it is loaded automatically.
# A2A_MESSAGES_FILE=<repo-root>/config/messages.json

# Admin HTTP server (host-only, no auth). Override if 39876 conflicts on shared boxes.
# A2A_EVENT_HOST=127.0.0.1
# A2A_EVENT_PORT=39876

# Logging
# A2A_LOG_FORMAT=json            # text (default) | json
# A2A_LOG_LEVEL=info             # error | warn | info | debug

# Per-turn timeout and retry policy
# A2A_TURN_TIMEOUT_MS=7200000    # default 2 hours; long internal searches should finish instead of restarting
# A2A_TURN_RETRY_ATTEMPTS=3
# A2A_TURN_RETRY_BASE_MS=2000
# A2A_TURN_RETRY_CAP_MS=30000

# Session-wide ceiling (defaults to 4 hours)
# A2A_SESSION_TIMEOUT_MS=14400000

# WS connection guard rails
# A2A_WS_RECONNECT_GIVEUP=10
# A2A_WS_RECONNECT_GIVEUP_MS=300000

# Codex SDK runtime tuning
# A2A_CODEX_PATH=<repo-root>/node_modules/.bin/codex   # auto-detected first; override if your install lives elsewhere
#
# A2A's defaults are permissive: sandbox=danger-full-access, web_search=live,
# approval=never. This matches Claude's permissionMode=dontAsk so both runtimes
# have the same reach into the host (Feishu CLIs, internal tools, curl, etc.). Set
# an empty value (e.g. `A2A_CODEX_SANDBOX=`) to fall through to ~/.codex/config.toml
# instead. Override for stricter posture on shared / multi-tenant deployments:
# A2A_CODEX_SANDBOX=workspace-write       # read-only | workspace-write | danger-full-access
# A2A_CODEX_APPROVAL=never                # never | on-failure | always
# A2A_CODEX_REASONING=xhigh
# A2A_CODEX_WEB_SEARCH=live               # live | off

# Claude Agent SDK runtime tuning
# A2A_CLAUDE_PATH=$HOME/.local/bin/claude  # auto-detected; override if your install lives elsewhere
# A2A_CLAUDE_PROFILE=<repo-root>/config/profiles/claude-relay.env
# A2A_CLAUDE_PERMISSION_MODE=dontAsk
# A2A_CLAUDE_EFFORT=max
